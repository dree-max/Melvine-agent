{
  "name": "melvine-agent",
  "version": "1.0.0",
  "description": "Personal AI Assistant with Claude backend",
  "main": "server/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server/index.js",
    "dev": "NODE_ENV=development node server/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint server/ --fix",
    "lint:check": "eslint server/",
    "format": "prettier --write \"server/**/*.js\"",
    "format:check": "prettier --check \"server/**/*.js\"",
    "security": "npm audit",
    "ci": "npm run lint:check && npm run test && npm run security"
  },
  "keywords": [
    "ai",
    "assistant",
    "claude",
    "personal-assistant",
    "react"
  ],
  "author": "dree-max",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "pino": "^8.17.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
